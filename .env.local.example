# Copy this file to .env.local and fill in real values.
# .env.local is covered by .env* in .gitignore — never commit it.

# ── Public (safe to expose to the browser) ───────────────────
# Uses the anon key only — Row Level Security enforces access control.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Private (server-side only) ───────────────────────────────
# MUST NOT be prefixed with NEXT_PUBLIC_ — that would expose it to the browser bundle.
# Used only in lib/supabase/admin.ts which imports 'server-only'.
# Grants full Supabase access, bypasses RLS — treat like a root password.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
